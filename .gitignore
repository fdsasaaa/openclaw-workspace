# OpenClaw Workspace .gitignore

# ============================================
# 敏感信息 - 绝对禁止提交
# ============================================
**/auth-profiles.json
**/api_key*
**/*secret*
**/*token*
**/*credential*
.env
.env.local

# ============================================
# 日志文件
# ============================================
*.log
bindings/logs/
logs/*.log
!logs/.gitkeep

# ============================================
# 临时文件
# ============================================
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ============================================
# 通知文件
# ============================================
bindings/notifications/

# ============================================
# 大文件/数据文件
# ============================================
Data/*.csv
Data/*.xlsx
Data/*.parquet
*.csv.gz
*.zip

# ============================================
# 视频和截图文件
# ============================================
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
screenshots/
videos/
*.png
*.jpg
*.jpeg
!docs/**/*.png
!docs/**/*.jpg

# ============================================
# 缓存文件
# ============================================
cache/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 备份文件
# ============================================
backup/
*.backup

# ============================================
# IDE/编辑器
# ============================================
.vscode/
.idea/

# ============================================
# OpenClaw 运行时文件
# ============================================
.openclaw/workspace-state.json
.clawhub/lock.json

# ============================================
# Node.js/Python
# ============================================
node_modules/
venv/
env/
.venv/

# ============================================
# 记忆文件保留
# ============================================
!memory/.gitkeep
