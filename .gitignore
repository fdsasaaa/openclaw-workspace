# OpenClaw Git同步排除规则
# 生成时间: 2026-03-05

# ============================================
# 敏感信息 - 绝对禁止提交
# ============================================
# API密钥、令牌、密码
**/auth-profiles.json
**/api_key*
**/*secret*
**/*token*
**/*credential*
.env
.env.local

# ============================================
# 大文件/数据文件
# ============================================
# 市场数据（CSV/XLSX通常很大）
Data/*.csv
Data/*.xlsx
Data/*.parquet
*.csv.gz
*.zip

# ============================================
# 临时文件
# ============================================
temp/
*.tmp
*.temp
*.log
*.lock

# ============================================
# 缓存文件
# ============================================
cache/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/

# ============================================
# 系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# 备份文件（保留在本地）
# ============================================
backup/
*.backup
*.bak

# ============================================
# IDE/编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# OpenClaw运行区（由系统管理，不同步）
# ============================================
workspace/

# ============================================
# Node.js/Python虚拟环境
# ============================================
node_modules/
venv/
env/
.venv/

# ============================================
# 可选：排除记忆文件（如不想同步）
# ============================================
# memory/*.md
# 保留记忆检查点
!memory/.gitkeep

# ============================================
# 可选：排除日志（如不想同步）
# ============================================
# logs/*.log
# 保留目录
!logs/.gitkeep
